{
  "_comment": "AI Morph Ads — single-variant ComfyUI API workflow. The driver script (scripts/run_pipeline.py) loads this JSON, patches the fields marked {{ ... }} per variant, and POSTs it to ComfyUI's /prompt endpoint four times (once per variant). Node IDs are stable strings so the driver can address them by key.",
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{sd15_checkpoint}}"
    },
    "_meta": {
      "title": "SD1.5 Base"
    }
  },
  "2": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "{{sd15_vae}}"
    },
    "_meta": {
      "title": "SD1.5 VAE"
    }
  },
  "3": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "{{lora}}",
      "strength_model": 0.8,
      "strength_clip": 0.8,
      "model": [
        "1",
        0
      ],
      "clip": [
        "1",
        1
      ]
    },
    "_meta": {
      "title": "Style LoRA"
    }
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{product_image}}"
    },
    "_meta": {
      "title": "Product image"
    }
  },
  "5": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "{{clip_vision}}"
    },
    "_meta": {
      "title": "CLIP Vision (IP-Adapter)"
    }
  },
  "6": {
    "class_type": "IPAdapterModelLoader",
    "inputs": {
      "ipadapter_file": "{{ipadapter_model}}"
    },
    "_meta": {
      "title": "IP-Adapter weights"
    }
  },
  "7": {
    "class_type": "IPAdapter",
    "inputs": {
      "weight": 0.6,
      "weight_type": "original",
      "start_at": 0.0,
      "end_at": 1.0,
      "model": [
        "3",
        0
      ],
      "ipadapter": [
        "6",
        0
      ],
      "image": [
        "4",
        0
      ],
      "clip_vision": [
        "5",
        0
      ]
    },
    "_meta": {
      "title": "IP-Adapter apply (identity lock)"
    }
  },
  "8": {
    "class_type": "CannyEdgePreprocessor",
    "inputs": {
      "image": [
        "4",
        0
      ],
      "low_threshold": 100,
      "high_threshold": 200,
      "resolution": 768
    },
    "_meta": {
      "title": "Canny preprocess"
    }
  },
  "9": {
    "class_type": "MiDaS-DepthMapPreprocessor",
    "inputs": {
      "image": [
        "4",
        0
      ],
      "a": 6.283185307179586,
      "bg_threshold": 0.1,
      "resolution": 768
    },
    "_meta": {
      "title": "Depth preprocess (MiDaS)"
    }
  },
  "10": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "{{controlnet_canny}}"
    },
    "_meta": {
      "title": "ControlNet — Canny"
    }
  },
  "11": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "{{controlnet_depth}}"
    },
    "_meta": {
      "title": "ControlNet — Depth"
    }
  },
  "12": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive_prompt}}",
      "clip": [
        "3",
        1
      ]
    },
    "_meta": {
      "title": "Positive prompt"
    }
  },
  "13": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": [
        "3",
        1
      ]
    },
    "_meta": {
      "title": "Negative prompt"
    }
  },
  "14": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "strength": 0.75,
      "start_percent": 0.0,
      "end_percent": 1.0,
      "positive": [
        "12",
        0
      ],
      "negative": [
        "13",
        0
      ],
      "control_net": [
        "10",
        0
      ],
      "image": [
        "8",
        0
      ]
    },
    "_meta": {
      "title": "Apply ControlNet — Canny"
    }
  },
  "15": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "strength": 0.50,
      "start_percent": 0.0,
      "end_percent": 1.0,
      "positive": [
        "14",
        0
      ],
      "negative": [
        "14",
        1
      ],
      "control_net": [
        "11",
        0
      ],
      "image": [
        "9",
        0
      ]
    },
    "_meta": {
      "title": "Apply ControlNet — Depth (stacked)"
    }
  },
  "16": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 768,
      "height": 768,
      "batch_size": 1
    },
    "_meta": {
      "title": "Empty latent (768²)"
    }
  },
  "17": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 28,
      "cfg": 7.5,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": [
        "7",
        0
      ],
      "positive": [
        "15",
        0
      ],
      "negative": [
        "15",
        1
      ],
      "latent_image": [
        "16",
        0
      ]
    },
    "_meta": {
      "title": "KSampler — SD1.5 stage"
    }
  },
  "18": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": [
        "17",
        0
      ],
      "vae": [
        "2",
        0
      ]
    },
    "_meta": {
      "title": "VAE decode — SD1.5 output"
    }
  },
  "19": {
    "class_type": "ImageScale",
    "inputs": {
      "upscale_method": "lanczos",
      "width": 1024,
      "height": 1024,
      "crop": "disabled",
      "image": [
        "18",
        0
      ]
    },
    "_meta": {
      "title": "Upscale to 1024² for SDXL pass"
    }
  },
  "20": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{sdxl_checkpoint}}"
    },
    "_meta": {
      "title": "SDXL Base (img2img pass)"
    }
  },
  "21": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive_prompt}}",
      "clip": [
        "20",
        1
      ]
    },
    "_meta": {
      "title": "SDXL positive"
    }
  },
  "22": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": [
        "20",
        1
      ]
    },
    "_meta": {
      "title": "SDXL negative"
    }
  },
  "23": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": [
        "19",
        0
      ],
      "vae": [
        "20",
        2
      ]
    },
    "_meta": {
      "title": "Re-encode for SDXL img2img"
    }
  },
  "24": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 20,
      "cfg": 6.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 0.30,
      "model": [
        "20",
        0
      ],
      "positive": [
        "21",
        0
      ],
      "negative": [
        "22",
        0
      ],
      "latent_image": [
        "23",
        0
      ]
    },
    "_meta": {
      "title": "KSampler — SDXL img2img refine"
    }
  },
  "25": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": [
        "24",
        0
      ],
      "vae": [
        "20",
        2
      ]
    },
    "_meta": {
      "title": "VAE decode — final 1024² image"
    }
  },
  "26": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "{{variant_id}}",
      "images": [
        "25",
        0
      ]
    },
    "_meta": {
      "title": "Save final PNG"
    }
  }
}
